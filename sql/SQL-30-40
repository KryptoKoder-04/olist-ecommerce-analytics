-- Q40️⃣ Rank sellers based on total revenue (use window function).

SELECT 
      seller_id,
	  SUM(price) AS total_revenue,
	  RANK() OVER (ORDER BY SUM(price) DESC) AS revenue_rank
FROM olist_order_items_dataset
GROUP BY seller_id;
	 